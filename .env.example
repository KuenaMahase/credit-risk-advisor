# OpenAI API key used by rag/llm.py for answer generation.
OPENAI_API_KEY=sk-...

# Optional: override the default chat model.
LLM_MODEL=gpt-4o-mini

# Required together when LLM_MODEL is not in rag/llm.py's pricing table.
# Prices are USD per 1M input/output tokens.
# LLM_PRICE_PER_M_INPUT=0.15
# LLM_PRICE_PER_M_OUTPUT=0.60
